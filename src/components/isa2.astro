---
const res = await fetch("https://dummyjson.com/products/158");
const product = await res.json();
---

<meta charset="UTF-8" />

<style>
  img {
    width: 100%;
    display: block;
    border-radius: 10px;
  }

  section {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  div {
    margin: 5px;
    width: 45%;
    background-color: #f6f5f3;
    border-radius: 10px;
  }

  section,
  div {
    position: relative;
  }

  h2,
  h3 {
    position: absolute;
    left: 20px;
    color: white;
  }

  h2 {
    bottom: 60px;
  }

  h3 {
    bottom: 20px;
  }

  @media screen and (max-width: 800px) {
    img {
    }
  }
</style>

<section>
  <div>
    <img src={product.thumbnail} alt={product.solbriller} />
  </div>
  <div>
    <img
      src="/img.isa/solbrille.dame.webp"
      alt="Billede af dame med solrbiller"
    />
  </div>
</section>
